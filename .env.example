# ============================================================
# ExpenseAudit AI — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# --- Required for full LLM pipeline ---
# Get your key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --- Required for pseudonymization (any random secret string) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PSEUDONYM_SALT=your_random_secret_salt_here

# --- Optional: Google Drive MCP export ---
# Path to a Google Drive MCP server credentials file (service account JSON)
# Leave empty to disable Drive export (system still runs fully without it)
GOOGLE_DRIVE_MCP_CREDENTIALS=

# --- Optional: API settings ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Optional: Logging ---
LOG_LEVEL=INFO
